
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions.
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'chines@trader.com' || 
        request.auth.token.email == 'estrategiachinesa@gmail.com'
      );
    }

    /**
     * Rules for App Configuration
     */
    match /appConfig/{configDoc} {
      allow read: if true;
      // Permite que qualquer pessoa incremente as estatísticas de analytics
      allow create, update: if configDoc == 'analytics' || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * Rules for VIP access requests.
     */
    match /vipRequests/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow write: if isAdmin() || (isSignedIn() && isOwner(userId));
      allow delete: if isAdmin();
    }
    
    /**
     * Main user data collection.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin() || (isSignedIn() && isOwner(userId));
      allow update: if isAdmin() || (isSignedIn() && isOwner(userId) && !isChangingSubscription());
      allow delete: if isAdmin();
    }

    /**
     * Prevents a user from modifying their own subscriptionStatus.
     */
    function isChangingSubscription() {
      return request.resource.data.subscriptionStatus != resource.data.subscriptionStatus;
    }

    /**
     * Generic rules for other public collections
     */
    match /session/{sessionDoc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /affiliates/{affDoc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
